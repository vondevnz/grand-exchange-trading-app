# Copy this file to .env and fill in your own values.
# .env is gitignored and should never be committed.

# A descriptive User-Agent identifying your app to the OSRS Wiki API.
# The wiki asks for something that identifies the project and, ideally,
# a way to contact you if there's an issue with your requests.
# Example: "grand-exchange-trading-app - github.com/vondevnz - your@email.com"
USER_AGENT_TEXT=your-app-name - your-github-or-contact-info
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname